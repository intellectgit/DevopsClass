metadata:
  namespace: dev-team
  name: pod-reader
rules:
- apiGroups: [""]# "" indicates the core API group
  resources: ["pod","service","deployment"]
  verbs: ["get", "watch", "list","update","create"]

Role binding 
=====================
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: RoleBinding
  namespace: dev-team
subjects:
- kind: ServiceAccount
  name: turmeric-dev
  namespace: dev-team  # It is best practice to explicitly state the namespace for the ServiceAccount
roleRef:
  kind: Role 
  name: pod-reader 
  apiGroup: rbac.authorization.k8s.io # Must be this string, not an array


